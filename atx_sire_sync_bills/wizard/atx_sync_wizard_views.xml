<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_atx_sync_wizard_form" model="ir.ui.view">
        <field name="name">atx.sync.wizard.form</field>
        <field name="model">atx.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Sincronizar con SUNAT SIRE">
                <group>
                    <field name="company_id"/>
                    <field name="atx_periodo" placeholder="Ej: 202504"/>
                </group>
                <footer>
                    <button name="action_sync" type="object"
                            string="Sincronizar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_atx_sync_wizard" model="ir.actions.act_window">
        <field name="name">Sincronizar Período SIRE</field>
        <field name="res_model">atx.sync.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
